% u24style.sty — Unified branding for U24 Post-Millennium Programme
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{u24style}[2026/03/31 U24 Programme House Style]

% Fonts: Palatino
\RequirePackage{newpxtext}
\RequirePackage{newpxmath}
\RequirePackage{microtype}

% Colours
\RequirePackage{xcolor}
\definecolor{u24navy}{HTML}{1B2A4A}
\definecolor{u24gold}{HTML}{C8A951}
\definecolor{proved}{RGB}{0,128,0}
\definecolor{conditional}{RGB}{204,102,0}
\definecolor{computational}{RGB}{0,0,204}
\definecolor{conjectural}{RGB}{180,0,0}

% Page geometry
\RequirePackage[margin=1.15in, top=1.3in, bottom=1.3in]{geometry}

% Headers
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\color{u24navy}\thepage}

% Sections
\RequirePackage{titlesec}
\titleformat{\section}{\Large\bfseries\color{u24navy}}{\thesection}{1em}{}[\color{u24navy}\titlerule]
\titleformat{\subsection}{\large\bfseries\color{u24navy}}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\bfseries\color{u24navy}}{\thesubsubsection}{1em}{}

% Hyperlinks
\RequirePackage{hyperref}
\hypersetup{colorlinks=true, linkcolor=u24navy, citecolor=u24navy, urlcolor=u24navy}

\endinput
